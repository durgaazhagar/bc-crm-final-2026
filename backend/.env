# Backend Environment Configuration
# Blood Donor CRM AI 2.0

# Server Configuration
PORT=5012
NODE_ENV=development

# Anthropic API - Get key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR-REAL-KEY-HERE

# MongoDB Atlas Configuration
# =============================
# Setup Instructions:
# 1. Create free cluster at https://cloud.mongodb.com
# 2. Enable network access (0.0.0.0/0 for development)
# 3. Create database user with username and password
# 4. Get connection string from: Connect → Drivers → Node.js
# 5. Replace <user> and <password> in the URI below
#
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
# Example: mongodb+srv://bloodconnect_admin:MySecurePass123@cluster0.abc123.mongodb.net/bloodconnect
#
# For Local MongoDB Development (if you have MongoDB installed):
# mongodb://localhost:27017/bloodconnect
# 
# Current: Local MongoDB for development (no setup needed)
# When ready for production, change to: mongodb+srv://<user>:<password>@cluster0.mongodb.net/bloodconnect
MONGO_URI=mongodb+srv://durgaazhagar123_db_user:durgaazhagar123@cluster0.7resxj9.mongodb.net/bloodconnect

# Database Retry Configuration
DB_MAX_RETRIES=5
DB_INITIAL_DELAY_MS=2000

# JWT
JWT_SECRET=bloodconnect-secret-2026
JWT_EXPIRY=7d

# Auth Fallback Mode
# If MongoDB is unavailable:
#   - AUTH_FALLBACK=true: Use in-memory auth store (development only)
#   - AUTH_FALLBACK=false: Reject requests and return error (production recommended)
AUTH_FALLBACK=true

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Email (optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Analytics
ANALYTICS_ENABLED=true

# Logging
LOG_LEVEL=info
