# Backend Environment Configuration Template
# Blood Donor CRM AI 2.0

# Server Configuration
PORT=5012
NODE_ENV=development

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-YOUR-REAL-KEY-HERE

# MongoDB Atlas Configuration
# Replace <user>, <password>, and <cluster> with your actual MongoDB Atlas credentials
# Get connection string from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/bloodconnect

# Database Retry Configuration
DB_MAX_RETRIES=5
DB_INITIAL_DELAY_MS=2000

# JWT
JWT_SECRET=bloodconnect-secret-2026
JWT_EXPIRY=7d

# Auth Fallback Mode
# Set to 'true' for in-memory auth during development
# Set to 'false' to enforce database requirement (production recommended)
AUTH_FALLBACK=false
